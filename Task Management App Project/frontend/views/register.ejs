<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Get Started - TaskMaster</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body style="background: white;">
    <%- include('partials/navbar') %>

        <div class="auth-layout">
            <div class="form-container">
                <div style="text-align: center; margin-bottom: 2.5rem;">
                    <h1 style="font-weight: 800; font-size: 2.25rem; letter-spacing: -1.5px; margin-bottom: 0.5rem;">
                        Create account</h1>
                    <p style="color: var(--text-muted); font-weight: 500;">Start managing your workflow today.</p>
                </div>

                <% if (locals.error) { %>
                    <div
                        style="background: #fff1f2; border: 1px solid #ffe4e6; color: var(--danger); padding: 1rem; border-radius: var(--radius-sm); margin-bottom: 2rem; font-size: 0.9rem; font-weight: 700;">
                        <i class="fas fa-exclamation-circle"></i>
                        <%= error %>
                    </div>
                    <% } %>

                        <form action="/auth/register" method="POST">
                            <div class="form-group">
                                <label>USERNAME</label>
                                <input type="text" name="username" class="form-input"
                                    placeholder="Choose a unique username" required>
                            </div>
                            <div class="form-group">
                                <label>PASSWORD</label>
                                <input type="password" name="password" class="form-input"
                                    placeholder="Minimum 6 characters" minlength="6" required>
                            </div>
                            <div class="form-group" style="margin-bottom: 2rem;">
                                <label>WORKSPACE ROLE</label>
                                <select name="role" class="form-input">
                                    <option value="user">Personal Project Member</option>
                                    <option value="admin">Platform Administrator</option>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-primary"
                                style="width: 100%; padding: 1.1rem; font-size: 1rem;">Create Account</button>
                        </form>

                        <p
                            style="text-align: center; margin-top: 2.5rem; color: var(--text-muted); font-size: 0.95rem; font-weight: 600;">
                            Already have an account? <a href="/login"
                                style="color: var(--primary); text-decoration: none; font-weight: 800;">Log in here</a>
                        </p>
            </div>
        </div>
</body>

</html>