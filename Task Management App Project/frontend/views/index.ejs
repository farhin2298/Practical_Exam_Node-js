<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TaskMaster - Easy Task Management</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('partials/navbar') %>

        <section class="hero">
            <div class="container">
                <h1>Manage your daily <br> tasks easily.</h1>
                <p>A simple and fast way to keep track of your work and stay organized.</p>
                <div style="display: flex; gap: 1rem; justify-content: center;">
                    <a href="/register" class="btn btn-primary" style="padding: 1rem 2.5rem; font-size: 1.1rem;">Start
                        for Free</a>
                    <a href="/login" class="btn btn-outline" style="padding: 1rem 2.5rem; font-size: 1.1rem;">Login
                        Now</a>
                </div>
            </div>
        </section>

        <section class="container" style="margin-top: 5rem;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 3rem;">
                <div style="text-align: center; padding: 2rem;">
                    <i class="fas fa-bolt" style="font-size: 2.5rem; color: var(--primary); margin-bottom: 1.5rem;"></i>
                    <h3 style="margin-bottom: 1rem;">Super Fast</h3>
                    <p style="color: var(--text-muted);">Add tasks and categories quickly. No waiting, just work.</p>
                </div>
                <div style="text-align: center; padding: 2rem;">
                    <i class="fas fa-shield-alt"
                        style="font-size: 2.5rem; color: var(--primary); margin-bottom: 1.5rem;"></i>
                    <h3 style="margin-bottom: 1rem;">Safe & Secure</h3>
                    <p style="color: var(--text-muted);">Your data is safe with us. We use the best security to protect
                        you.</p>
                </div>
                <div style="text-align: center; padding: 2rem;">
                    <i class="fas fa-chart-pie"
                        style="font-size: 2.5rem; color: var(--primary); margin-bottom: 1.5rem;"></i>
                    <h3 style="margin-bottom: 1rem;">Simple Dashboard</h3>
                    <p style="color: var(--text-muted);">See how many tasks are done or pending with simple charts.</p>
                </div>
            </div>
        </section>

        <footer class="footer">
            <div class="container">
                <span class="footer-logo">TaskMaster</span>
                <p class="footer-copy">© 2026 TaskMaster. Simple Task Manager.</p>
            </div>
        </footer>
</body>

</html>