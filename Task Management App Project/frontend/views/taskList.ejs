<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - TaskMaster</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('partials/navbar') %>

        <main class="container">
            <header class="dashboard-header">
                <div>
                    <p
                        style="font-weight: 700; color: var(--primary); font-size: 0.9rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 1px;">
                        Home Dashboard</p>
                    <h1 style="font-weight: 800; font-size: 2.25rem; letter-spacing: -1px; color: var(--secondary);">
                        Hello, <%= user.username %>!
                    </h1>
                </div>
                <% if (!showAll) { %>
                    <a href="/tasks/add" class="btn btn-primary"><i class="fas fa-plus"></i> Add New Task</a>
                    <% } %>
            </header>

            <!-- Stats Section -->
            <div class="stats-grid">
                <div class="stat-card">
                    <h4>Total Tasks</h4>
                    <div class="value">
                        <%= tasks.length %>
                    </div>
                    <div
                        style="height: 4px; width: 40px; background: var(--border); margin-top: 1rem; border-radius: 2px;">
                    </div>
                </div>
                <div class="stat-card">
                    <h4>In Progress</h4>
                    <div class="value" style="color: var(--primary);">
                        <%= tasks.filter(t=> t.status === 'in-progress').length %>
                    </div>
                </div>
                <div class="stat-card">
                    <h4>Completed</h4>
                    <div class="value" style="color: var(--success);">
                        <%= tasks.filter(t=> t.status === 'completed').length %>
                    </div>
                </div>
            </div>

            <div style="margin-bottom: 2rem; display: flex; align-items: center; justify-content: space-between;">
                <h3 style="font-weight: 800; letter-spacing: -0.5px;">
                    <%= showAll ? 'All User Tasks' : 'My Current Tasks' %>
                </h3>
                <% if (user.role==='admin' ) { %>
                    <a href="<%= showAll ? '/tasks' : '/tasks?all=true' %>" class="btn btn-outline"
                        style="padding: 0.5rem 1rem; font-size: 0.8rem;">
                        <%= showAll ? 'Show My Tasks' : 'Show All Tasks' %>
                    </a>
                    <% } %>
            </div>

            <div class="task-grid">
                <% if (tasks.length> 0) { %>
                    <% for(let i=0; i < tasks.length; i++) { let task=tasks[i]; %>
                        <%- include('partials/taskItem', { task: task, index: i, showAll: showAll }) %>
                            <% } %>
                                <% } else { %>
                                    <div
                                        style="grid-column: 1 / -1; text-align: center; padding: 6rem 2rem; background: white; border-radius: 24px; border: 2px dashed var(--border);">
                                        <i class="fas fa-folder-open"
                                            style="font-size: 3rem; color: var(--border); margin-bottom: 1.5rem;"></i>
                                        <h2 style="font-weight: 800; margin-bottom: 0.5rem;">No tasks yet!</h2>
                                        <p style="color: var(--text-muted); margin-bottom: 2.5rem;">Click the button
                                            below to add your first task.</p>
                                        <a href="/tasks/add" class="btn btn-primary">Create Your First Task</a>
                                    </div>
                                    <% } %>
            </div>
        </main>

        <footer class="footer">
            <div class="container">
                <span class="footer-logo">TaskMaster</span>
                <p class="footer-copy">© 2026 Simple Task Manager. All rights reserved.</p>
            </div>
        </footer>
</body>

</html>