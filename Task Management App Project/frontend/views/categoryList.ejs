<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Categories - TaskMaster</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('partials/navbar') %>

        <main class="container">
            <header class="dashboard-header" style="justify-content: center; text-align: center; padding: 60px 0;">
                <div>
                    <p
                        style="font-weight: 700; color: var(--primary); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 1rem;">
                        Manage Categories</p>
                    <h1 style="font-weight: 800; font-size: 2.5rem; letter-spacing: -1.5px;">Your Categories</h1>
                    <p style="color: var(--text-muted); margin-top: 0.5rem;">Create and manage groups for your tasks
                        (like Work, Home, etc).</p>
                </div>
            </header>

            <div class="form-container" style="margin: 0 auto 4rem; max-width: 550px; padding: 2.5rem;">
                <h3 style="margin-bottom: 1.5rem; font-weight: 800; font-size: 1.25rem;">Add New Category</h3>
                <form action="/categories" method="POST">
                    <div class="form-group">
                        <label>CATEGORY NAME</label>
                        <input type="text" name="name" class="form-input" placeholder="e.g. Work, Home, Personal"
                            required>
                    </div>
                    <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem;">ADD
                        CATEGORY</button>
                </form>
            </div>

            <div style="max-width: 900px; margin: 0 auto 100px;">
                <h4
                    style="font-weight: 800; color: var(--secondary); margin-bottom: 2rem; display: flex; align-items: center; gap: 0.75rem;">
                    <i class="fas fa-tags" style="color: var(--primary);"></i> Active Categories
                </h4>
                <div class="task-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
                    <% if (categories.length> 0) { %>
                        <% categories.forEach(cat=> { %>
                            <div class="task-card"
                                style="display: flex; justify-content: space-between; align-items: center; padding: 1.5rem 2rem;">
                                <span style="font-weight: 800; font-size: 1.1rem; color: var(--secondary);">
                                    <%= cat.name %>
                                </span>
                                <form action="/categories/delete/<%= cat._id %>" method="POST"
                                    onsubmit="return confirm('Do you want to delete this category?');"
                                    style="margin: 0;">
                                    <button type="submit" class="btn"
                                        style="background: #fff1f2; color: var(--danger); font-weight: 800; padding: 0.5rem 1rem; font-size: 0.75rem;">DELETE</button>
                                </form>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div
                                        style="grid-column: 1 / -1; text-align: center; padding: 4rem; background: white; border-radius: 20px; border: 2px dashed var(--border);">
                                        <p style="color: var(--text-muted); font-weight: 600;">You haven't added any
                                            categories yet.</p>
                                    </div>
                                    <% } %>
                </div>
            </div>
        </main>

        <footer class="footer">
            <div class="container">
                <span class="footer-logo">TaskMaster</span>
                <p class="footer-copy">© 2026 Simple Task Design.</p>
            </div>
        </footer>
</body>

</html>