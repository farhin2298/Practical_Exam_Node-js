<% const t=locals.task || {}; const showAll=(locals.showAll===true); const i=locals.index || 0; const s=t.status
    || 'pending' ; let name='Unknown' ; let isAdm=false; if (t.user && typeof t.user==='object' ) { name=t.user.username
    || 'Unknown' ; isAdm=(t.user.role==='admin' ); } %>
    <div class="task-card <%= s %>" style="animation-delay: <%= (i * 0.1).toFixed(1) %>s;">
           <% if (showAll) { %>
            <div class="owner-badge"
                style="background: <%= isAdm ? 'var(--primary-dark)' : 'var(--secondary)' %>; color: white !important;">
                <i class="fas <%= isAdm ? 'fa-user-shield' : 'fa-user' %>"></i>
                <%= name %>
            </div>
            <% } %>

                <div
                    style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem;">
                    <span class="task-tag"
                        style="background: #f1f5f9; padding: 0.4rem 0.8rem; border-radius: 8px; color: var(--text-muted); border: 1px solid var(--border);">
                        <%= (t.category && t.category.name) ? t.category.name : 'No Category' %>
                    </span>

                    <div class="status-indicator">
                        <span class="dot"></span>
                        <span style="color: var(--text-muted);">
                            <%= s.replace('-', ' ' ) %>
                        </span>
                    </div>
                </div>

                <h3
                    style="font-weight: 800; font-size: 1.4rem; margin-bottom: 0.75rem; color: var(--secondary); letter-spacing: -0.5px;">
                    <%= t.title || 'Untitled Task' %>
                </h3>

                <p
                    style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6; margin-bottom: 2.5rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 3rem; line-clamp: 2;">
                    <%= t.description || 'No description available' %>
                </p>

                <div
                    style="display: flex; justify-content: space-between; align-items: center; padding-top: 1.5rem; border-top: 1px solid #f1f5f9; margin-top: auto;">
                    <div
                        style="display: flex; align-items: center; gap: 0.5rem; color: #94a3b8; font-size: 0.75rem; font-weight: 700;">
                        <i class="far fa-calendar-alt"></i>
                        <%= t.createdAt ? new Date(t.createdAt).toLocaleDateString(undefined, { month: 'short' ,
                            day: 'numeric' }) : 'No date' %>
                    </div>

                    <div style="display: flex; gap: 0.75rem;">
                        <a href="/tasks/edit/<%= t._id %>" class="btn-outline"
                            style="padding: 0.5rem 1rem; border-radius: 10px; font-size: 0.75rem; text-decoration: none; font-weight: 800;">
                            <i class="fas fa-pen" style="font-size: 0.7rem;"></i> EDIT
                        </a>

                        <form action="/tasks/delete/<%= t._id %>" method="POST"
                            onsubmit="return confirm('Delete this task?');" style="margin: 0;">
                            <button type="submit" class="btn"
                                style="background: #fff1f2; color: var(--danger); padding: 0.5rem 1rem; border-radius: 10px; border: none; font-weight: 800; font-size: 0.75rem; cursor: pointer;">
                                <i class="fas fa-trash" style="font-size: 0.7rem;"></i> DELETE
                            </button>
                        </form>
                    </div>
                </div>
    </div>