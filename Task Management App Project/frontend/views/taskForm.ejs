<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= task ? 'Edit Task' : 'Add New Task' %> - TaskMaster
    </title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('partials/navbar') %>

        <main class="container">
            <header class="dashboard-header" style="justify-content: center; text-align: center; padding: 50px 0;">
                <div>
                    <p
                        style="font-weight: 700; color: var(--primary); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 1rem;">
                        Task Settings</p>
                    <h1 style="font-weight: 800; font-size: 2.5rem; letter-spacing: -1.5px;">
                        <%= task ? 'Edit Your Task' : 'Create New Task' %>
                    </h1>
                </div>
            </header>

            <div class="form-container" style="margin: 0 auto 100px;">
                <form action="<%= task ? '/tasks/edit/' + task._id : '/tasks' %>" method="POST">
                    <div class="form-group">
                        <label>TASK NAME</label>
                        <input type="text" name="title" class="form-input" placeholder="What needs to be done?"
                            value="<%= task ? task.title : '' %>" required>
                    </div>

                    <div class="form-group">
                        <label>TASK DETAILS</label>
                        <textarea name="description" class="form-input" rows="5"
                            placeholder="Add more details about this task here..."
                            required><%= task ? task.description : '' %></textarea>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2.5rem;">
                        <div class="form-group" style="margin-bottom: 0;">
                            <label>STATUS</label>
                            <select name="status" class="form-input">
                                <option value="pending" <%=task && task.status==='pending' ? 'selected' : '' %>>📅
                                    PENDING</option>
                                <option value="in-progress" <%=task && task.status==='in-progress' ? 'selected' : '' %>
                                    >🚀 IN PROGRESS</option>
                                <option value="completed" <%=task && task.status==='completed' ? 'selected' : '' %>>✅
                                    COMPLETED</option>
                            </select>
                        </div>

                        <div class="form-group" style="margin-bottom: 0;">
                            <label>CATEGORY</label>
                            <select name="category" class="form-input">
                                <option value="">NO CATEGORY</option>
                                <% categories.forEach(cat=> { %>
                                    <option value="<%= cat._id %>" <%=task && task.category &&
                                        task.category.toString()===cat._id.toString() ? 'selected' : '' %>>
                                        🔖 <%= cat.name.toUpperCase() %>
                                    </option>
                                    <% }) %>
                            </select>
                        </div>
                    </div>

                    <div style="display: flex; gap: 1rem;">
                        <button type="submit" class="btn btn-primary" style="flex: 2; padding: 1rem;">
                            <%= task ? 'SAVE CHANGES' : 'ADD TASK' %>
                        </button>
                        <a href="/tasks" class="btn btn-outline" style="flex: 1;">CANCEL</a>
                    </div>
                </form>
            </div>
        </main>

        <footer class="footer">
            <div class="container">
                <span class="footer-logo">TaskMaster</span>
                <p class="footer-copy">© 2026 Simple Task Design.</p>
            </div>
        </footer>
</body>

</html>