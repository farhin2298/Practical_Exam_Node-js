<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - TaskMaster</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <div class="container" style="text-align: center; margin-top: 5rem;">
        <h1 style="color: var(--danger); font-size: 3rem;">Oops!</h1>
        <p style="margin: 1.5rem 0; color: var(--text-muted);">
            <%= error %>
        </p>
        <a href="/" class="btn btn-primary" style="width: auto; display: inline-block;">Go Back Home</a>
    </div>
</body>

</html>